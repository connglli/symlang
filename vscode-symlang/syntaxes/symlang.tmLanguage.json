{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SymLang",
  "scopeName": "source.symlang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#identifiers" },
    { "include": "#literals" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.symlang",
          "match": "//.*"
        },
        {
          "name": "comment.block.symlang",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.symlang",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.symlang",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "comment": "Control-flow terminators",
          "name": "keyword.control.symlang",
          "match": "\\b(br|ret|unreachable)\\b"
        },
        {
          "comment": "Path assertions / assumptions",
          "name": "keyword.control.assertion.symlang",
          "match": "\\b(assume|require)\\b"
        },
        {
          "comment": "Memory and pointer operations (v0.2.0)",
          "name": "keyword.control.symlang",
          "match": "\\b(addr|load|store)\\b"
        },
        {
          "comment": "Expression keywords",
          "name": "keyword.other.expression.symlang",
          "match": "\\b(select|as)\\b"
        },
        {
          "comment": "Declaration keywords",
          "name": "keyword.other.declaration.symlang",
          "match": "\\b(struct|fun|sym|let|mut|value|coef|index|in)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "comment": "Pointer type constructor (v0.2.0)",
          "name": "support.type.pointer.symlang",
          "match": "\\bptr\\b"
        },
        {
          "comment": "Integer types: i8, i16, i32, i64, iN",
          "name": "support.type.integer.symlang",
          "match": "\\bi[0-9]+\\b"
        },
        {
          "comment": "Floating-point types",
          "name": "support.type.float.symlang",
          "match": "\\b(f32|f64)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "comment": "Null pointer constant (v0.2.0)",
          "name": "constant.language.null.symlang",
          "match": "\\bnull\\b"
        },
        {
          "comment": "Uninitialized value sentinel",
          "name": "constant.language.undef.symlang",
          "match": "\\bundef\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "comment": "Global symbol: @?name",
          "name": "variable.other.symbol.global.symlang",
          "match": "@\\?[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "comment": "Local symbol: %?name",
          "name": "variable.other.symbol.local.symlang",
          "match": "%\\?[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "comment": "Function / struct name: @name",
          "name": "entity.name.function.symlang",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "comment": "Local variable: %name",
          "name": "variable.other.local.symlang",
          "match": "%[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "comment": "Block label: ^name",
          "name": "entity.name.label.symlang",
          "match": "\\^[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.numeric.hex.symlang",
          "match": "-?0x[0-9a-fA-F]+"
        },
        {
          "name": "constant.numeric.octal.symlang",
          "match": "-?0o[0-7]+"
        },
        {
          "name": "constant.numeric.binary.symlang",
          "match": "-?0b[01]+"
        },
        {
          "name": "constant.numeric.float.symlang",
          "match": "-?[0-9]+\\.[0-9]+([eE][-+]?[0-9]+)?"
        },
        {
          "name": "constant.numeric.decimal.symlang",
          "match": "-?[0-9]+"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.symlang",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.bitwise.symlang",
          "match": ">>>|>>|<<|&|\\||\\^|~"
        },
        {
          "name": "keyword.operator.arithmetic.symlang",
          "match": "\\+|\\-|\\*|/|%"
        },
        {
          "name": "keyword.operator.assignment.symlang",
          "match": "="
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.symlang",
          "match": ";"
        },
        {
          "name": "punctuation.separator.symlang",
          "match": ",|:"
        },
        {
          "name": "punctuation.accessor.symlang",
          "match": "\\."
        },
        {
          "name": "punctuation.section.block.begin.symlang",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.symlang",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.brackets.begin.symlang",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.symlang",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.parens.begin.symlang",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.symlang",
          "match": "\\)"
        }
      ]
    }
  }
}
