// EXPECT: FAIL

// Definite-init analysis: reading a lane of a vector initialised with
// `undef` is rejected by the static analysis (warning at minimum;
// dynamic UB rule 22 catches what static analysis misses).
fun @main() : i32 {
  let mut %v: <4> i32 = undef;
  let mut %x: i32 = 0;
^entry:
  %x = %v[2];   // FAIL: reading lane from undef-initialized vector
  ret %x;
}
