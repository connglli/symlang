// EXPECT: FAIL:StaticError

// Constant lane index outside [0, N) is a compile-time error
// (same treatment as out-of-bounds constant array index in v0.2.0).
fun @main() : i32 {
  let %v: <4> i32 = {1, 2, 3, 4};
  let mut %x: i32 = 0;
^entry:
  %x = %v[10];   // StaticError: 10 >= N = 4
  ret %x;
}
