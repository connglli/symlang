// EXPECT: PASS

// Whole-vector assignment is well-typed (§6.6 assignment rule: same type,
// register-shaped bitwidth). Vectors have bitwidth N * bitwidth(T).
fun @main() : i32 {
  let %w: <4> i32 = {1, 2, 3, 4};
  let mut %v: <4> i32 = 0;
^entry:
  %v = %w;          // vector copy by value
  ret 0;
}
