// EXPECT: PASS
// SOLVER_ARGS: --main @main --path ^entry,^stage1,^stage2,^exit -I test/lib/std/simd
// SKIP: SOLVER -- vector-typed decl param via -I link-form triggers "Empty term handle" (solver gap)
// SPEC v0.2.2 §9.6.1 + §11.1 + §2.11 (vectors)
// Intention: Scenario B3 -- simd stdlib helper @reduce_add_4_i32
// (vector-by-value through link-form decl). Same-module callees
// accept vectors fine (see scenario A6), but decl-form vector params
// currently fail at the solver's term-building stage.
decl @reduce_add_4_i32(%v: <4> i32) : i32;

fun @inc(%x: i32) : i32 {
^entry:
  ret %x + 1;
}

fun @main() : i32 {
  sym %?a: value i32 in [0, 10];
  sym %?b: value i32 in [0, 10];
  sym %?c: value i32 in [0, 10];
  sym %?d: value i32 in [0, 10];
  let mut %v: <4> i32 = { 0, 0, 0, 0 };
  let mut %s: i32 = 0;
  let mut %check: i32 = 0;
  let mut %final: i32 = 0;
  let %i0: i32 = 0;
  let %i1: i32 = 1;
  let %i2: i32 = 2;
  let %i3: i32 = 3;
  let %target_sum: i32 = 16;
^entry:
  %v[%i0] = %?a;
  %v[%i1] = %?b;
  %v[%i2] = %?c;
  %v[%i3] = %?d;
  %s = call @reduce_add_4_i32(%v);
  require %s == %target_sum, "lane sum equals 16";
  br ^stage1;
^stage1:
  %check = call @inc(%s);
  require %check == 17, "inc(16) == 17";
  br ^stage2;
^stage2:
  %final = %check - 1;
  require %final == %target_sum, "final equals target";
  require %?a + %?b + %?c + %?d == %target_sum, "manual cross-check";
  br ^exit;
^exit:
  ret %s;
}
