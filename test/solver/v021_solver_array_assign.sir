// EXPECT: FAIL:StaticError
// SOLVER_ARGS: --main @main --path '^entry'
//
// Rationale: Whole-array assignment is not supported (§6.6).

fun @main() : i32 {
  let mut %arr1: [2] i32 = {10, 20};
  let mut %arr2: [2] i32 = {0, 0};
^entry:
  %arr2 = %arr1;
  require %arr2[0] == 10;
  require %arr2[1] == 20;
  ret 0;
}
