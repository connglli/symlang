// EXPECT: PASS
// SOLVER_ARGS: --main @main --path ^entry,^validate,^check,^finalize,^exit
// SKIP: SOLVER -- ptr [N] T callee params trigger solver UNSAT (gap in v0.2.2)
// SPEC v0.2.2 §9.6.1 + §6.10 + §13
// Intention: Scenario A9 -- helper synthesized to satisfy a require
// that involves aggregate state. The caller writes symbols into a
// [4] i32 array, the helper sums them, and the require constrains the
// total. Documents an open solver gap: passing `ptr [N] T` to a fun
// callee and reading via ptrindex is currently UNSAT in the inlining
// pipeline.
fun @sum_4(%p: ptr [4] i32) : i32 {
  let %i0: i32 = 0;
  let %i1: i32 = 1;
  let %i2: i32 = 2;
  let %i3: i32 = 3;
  let mut %elt: ptr i32 = null;
  let mut %v: i32 = 0;
  let mut %s: i32 = 0;
^entry:
  %elt = ptrindex %p, %i0; %v = load %elt; %s = %s + %v;
  %elt = ptrindex %p, %i1; %v = load %elt; %s = %s + %v;
  %elt = ptrindex %p, %i2; %v = load %elt; %s = %s + %v;
  %elt = ptrindex %p, %i3; %v = load %elt; %s = %s + %v;
  ret %s;
}

fun @read_at(%p: ptr [4] i32, %i: i32) : i32 {
  let mut %elt: ptr i32 = null;
^entry:
  %elt = ptrindex %p, %i;
  ret load %elt;
}

fun @main() : i32 {
  sym %?a: value i32 in [0, 10];
  sym %?b: value i32 in [0, 10];
  sym %?c: value i32 in [0, 10];
  sym %?d: value i32 in [0, 10];
  let mut %arr: [4] i32 = { 0, 0, 0, 0 };
  let mut %p: ptr [4] i32 = null;
  let mut %s: i32 = 0;
  let mut %first: i32 = 0;
  let mut %final: i32 = 0;
  let %i0: i32 = 0;
  let %target: i32 = 20;
  let %first_target: i32 = 5;
^entry:
  %arr[0] = %?a;
  %arr[1] = %?b;
  %arr[2] = %?c;
  %arr[3] = %?d;
  %p = addr %arr;
  %s = call @sum_4(%p);
  require %s == %target, "array sum == 20";
  br ^validate;
^validate:
  %first = call @read_at(%p, %i0);
  require %first == %first_target, "arr[0] == 5";
  br ^check;
^check:
  require %?a == %first_target, "?a is the first element";
  br ^finalize;
^finalize:
  %final = %s - %first;
  require %final == 15, "remaining three lanes sum to 15";
  br ^exit;
^exit:
  ret %?a;
}
