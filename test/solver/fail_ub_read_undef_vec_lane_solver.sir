// EXPECT: FAIL:UndefinedBehavior
// SOLVER_ARGS: --main @main --path ^entry
// SKIP: INTERPRETER

// Testing Rule 22: Reading an undef vector lane in solver.

fun @main() : i32 {
  let mut %v: <4> i32 = undef;
  let mut %res: i32 = 0;
^entry:
  // We didn't initialize %v[0]
  %res = %v[0];
  ret %res;
}
