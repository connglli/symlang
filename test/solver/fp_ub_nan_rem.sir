// EXPECT: FAIL:UndefinedBehavior
// SOLVER_ARGS: --main @test --path ^entry
// SKIP: COMPILER
// 1.0 % x where x == 0.0 gives NaN; isFinite(1.0 % x) in PC → UNSAT
fun @test() : f32 {
  sym %?x : value f32;
  let %zero: f32 = 0.0;
  let %one: f32 = 1.0;
  let mut %a: f32 = 0.0;
  let mut %r: f32 = 0.0;
^entry:
  assume %?x == %zero;
  %a = %?x;
  %r = %one % %a;
  require %r != %zero;
  ret %?x;
}
