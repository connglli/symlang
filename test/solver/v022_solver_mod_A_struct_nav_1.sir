// EXPECT: PASS
// SOLVER_ARGS: --main @main --path ^entry,^load_stage,^check,^done,^exit
// SKIP: SOLVER -- ptr @S to fun callee + ptrfield/load returns UNSAT (solver gap)
// SPEC v0.2.2 §9.6.1 + §6.10
// Intention: Scenario A5 -- helper takes a struct pointer, navigates
// with ptrfield to inspect both fields. Even with the documented
// solver gap on ptrfield-derived pointers (§13), this is a
// straight-line use case via direct addr %lv (rule 15) that the
// current solver should handle.
struct @Pair { x: i32; y: i32; }

fun @sum_pair(%p: ptr @Pair) : i32 {
  let mut %xp: ptr i32 = null;
  let mut %yp: ptr i32 = null;
  let mut %xv: i32 = 0;
  let mut %yv: i32 = 0;
^entry:
  %xp = ptrfield %p, x;
  %yp = ptrfield %p, y;
  %xv = load %xp;
  %yv = load %yp;
  ret %xv + %yv;
}

fun @sub_pair(%p: ptr @Pair) : i32 {
  let mut %xp: ptr i32 = null;
  let mut %yp: ptr i32 = null;
  let mut %xv: i32 = 0;
  let mut %yv: i32 = 0;
^entry:
  %xp = ptrfield %p, x;
  %yp = ptrfield %p, y;
  %xv = load %xp;
  %yv = load %yp;
  ret %xv - %yv;
}

fun @main() : i32 {
  sym %?a: value i32 in [0, 50];
  sym %?b: value i32 in [0, 50];
  let mut %pair: @Pair = {0, 0};
  let mut %p: ptr @Pair = null;
  let mut %s: i32 = 0;
  let mut %d: i32 = 0;
  let mut %prod: i32 = 0;
  let %sum_target: i32 = 30;
  let %diff_target: i32 = 10;
^entry:
  %pair.x = %?a;
  %pair.y = %?b;
  %p = addr %pair;
  %s = call @sum_pair(%p);
  require %s == %sum_target, "?a + ?b == 30";
  br ^load_stage;
^load_stage:
  %d = call @sub_pair(%p);
  require %d == %diff_target, "?a - ?b == 10";
  br ^check;
^check:
  // System: a == 20, b == 10
  %prod = %s + %d;
  require %prod == 40, "sum + diff equals 2a";
  br ^done;
^done:
  br ^exit;
^exit:
  ret %?a;
}
