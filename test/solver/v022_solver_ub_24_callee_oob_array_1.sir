// EXPECT: FAIL:UndefinedBehavior
// SOLVER_ARGS: --main @main --path ^entry,^use,^exit -I test/lib/std/scalar
// SKIP: INTERPRETER — UB only on symbolic path
// SKIP: COMPILER — UB only observable via solver
// SPEC v0.2.2 §7.7 rule 24 (via rule 2 inside callee)
// Intention: callee reads `%a[%?i]` where %?i is unconstrained and
// caller forces it out-of-bounds. Path is infeasible.
intrinsic @min(%a: i32, %b: i32) : i32;
decl @sign(%x: i32) : i32;

fun @reader(%i: i32) : i32 {
  let mut %a: [4] i32 = { 10, 20, 30, 40 };
  let mut %t: i32 = 0;
  let mut %u: i32 = 0;
  let %one: i32 = 1;
^entry:
  %t = call @min(%i, 100);
  %u = %t + %one;
  br %u >= 0, ^read, ^skip;
^read:
  %t = %a[%i];           // rule 2: array OOB when %i >= 4 or %i < 0
  %u = %t + %one;
  br %u > 0, ^use, ^skip;
^use:
  %t = %u + %u;
  ret %t;
^skip:
  ret %one;
}

fun @main() : i32 {
  sym %?i: value i32 in [-100, 100];
  let mut %r: i32 = 0;
  let mut %s: i32 = 0;
^entry:
  %s = call @sign(%?i);
  br %s != 0, ^use, ^skip;
^use:
  require %?i >= 4, "force OOB access in callee";
  %r = call @reader(%?i);
  br ^exit;
^skip:
  br ^exit;
^exit:
  ret %r;
}
