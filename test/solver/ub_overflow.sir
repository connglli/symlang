// EXPECT: FAIL:UndefinedBehavior
// SKIP: WASM
// Reason: WASM doesn't support ASan/UBSan style runtime trapping for signed integer addition overflow.
// SKIP: SOLVER
// SOLVER_ARGS: --main @main --path ^entry
// COMPILER_ARGS: --sym %?a=2147483647

// Addition overflow (MAX_INT32 + 1) is strict UB — solver should detect infeasibility.
fun @main() : i32 {
  sym %?a : value i32;
  let %one: i32 = 1;
  let mut %x: i32 = 0;
^entry:
  %x = %?a;
  ret %x + %one;
}
