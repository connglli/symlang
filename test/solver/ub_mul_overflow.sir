// EXPECT: FAIL:UndefinedBehavior
// SKIP: WASM
// SKIP: SOLVER
// SOLVER_ARGS: --main @main --path ^entry
// COMPILER_ARGS: --sym %?a=2147483647

// Multiplication overflow (MAX_INT32 * 2) is strict UB and should fail.
fun @main() : i32 {
  sym %?a : value i32;
  let %two: i32 = 2;
  let mut %x: i32 = 0;
^entry:
  %x = %?a;
  ret %x * %two;
}
