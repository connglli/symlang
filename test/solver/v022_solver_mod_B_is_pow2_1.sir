// EXPECT: PASS
// SOLVER_ARGS: --main @main --path ^entry,^post,^check,^exit -I test/lib/std/scalar
// SPEC v0.2.2 §11.1 + §12.2 (@popcount intrinsic)
// Intention: Scenario B8 -- straight-line stdlib helper
// @count_ones_i32 (thin wrapper over @popcount intrinsic). The solver
// synthesizes %?x in [0, 256] such that popcount(?x) == 4 (i.e. ?x has
// exactly 4 set bits, e.g. 0b1111 = 15).
decl @count_ones_i32(%x: i32) : i32;

fun @plus_one(%v: i32) : i32 {
^entry:
  ret %v + 1;
}

fun @main() : i32 {
  sym %?x: value i32 in [0, 256];
  let mut %pc: i32 = 0;
  let mut %pc2: i32 = 0;
  let mut %incr: i32 = 0;
  let mut %final: i32 = 0;
  let %target: i32 = 4;
^entry:
  %pc = call @count_ones_i32(%?x);
  require %pc == %target, "popcount(?x) == 4";
  br ^post;
^post:
  // Re-call to verify shared-symbol semantics (§9.6.1 note).
  %pc2 = call @count_ones_i32(%?x);
  require %pc2 == %pc, "second call yields the same popcount";
  br ^check;
^check:
  %incr = call @plus_one(%pc);
  require %incr == 5, "plus_one(4) == 5";
  %final = %incr - 1;
  require %final == %target, "round trip preserves target";
  br ^exit;
^exit:
  ret %?x;
}
