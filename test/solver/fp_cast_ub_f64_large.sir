// EXPECT: FAIL:UndefinedBehavior
// SOLVER_ARGS: --main @test --path ^entry
// SKIP: COMPILER
// x > 1.0e19 forces x as i64 to overflow; range PC constraint → UNSAT
fun @test() : i64 {
  sym %?x : value f64;
  let %bound: f64 = 1.0e19;
  let %zero: i64 = 0;
  let mut %r: i64 = 0;
^entry:
  assume %?x > %bound;
  %r = %?x as i64;
  require %r > %zero;
  ret %r;
}
