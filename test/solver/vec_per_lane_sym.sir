// EXPECT: PASS
// SOLVER_ARGS: --main @main --path '^entry'
// INTERP_ARGS: --main @main --sym %?v=2,3,4,5
// COMPILER_ARGS: --main @main --sym %?v=2,3,4,5

// Solve for a 4-lane vector sym such that each lane equals its index+2.
// LValue.base is LocalId only, so we stage %?v into a let mut local
// before subscripting (§5.1).
fun @main() : i32 {
  sym %?v: value <4> i32 in [0, 10];
  let mut %t: <4> i32 = 0;
^entry:
  %t = %?v;
  require %t[0] == 2, "lane 0";
  require %t[1] == 3, "lane 1";
  require %t[2] == 4, "lane 2";
  require %t[3] == 5, "lane 3";
  ret 0;
}
