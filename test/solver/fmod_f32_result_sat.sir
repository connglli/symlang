// EXPECT: PASS
// SOLVER_ARGS: --main @test --path ^entry
// x in [1.25, 1.75]: fmod(x, 1.0) = x - 1 in [0.25, 0.75] — positive, away from boundary.
// require r > 0.0 is SAT.
// SKIP: COMPILER
fun @test() : f32 {
  sym %?x : value f32;
  let %lo: f32 = 1.25;
  let %hi: f32 = 1.75;
  let %one: f32 = 1.0;
  let %zero: f32 = 0.0;
  let mut %r: f32 = 0.0;
^entry:
  assume %?x >= %lo;
  assume %?x <= %hi;
  %r = %?x % %one;
  require %r > %zero;
  ret %r;
}
