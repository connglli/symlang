// EXPECT: PASS
// SOLVER_ARGS: --main @main --path ^entry,^post_clamp,^post_swap,^post_sum,^exit -I test/lib/std/scalar -I test/lib/std/collections
// SKIP: SOLVER -- ptr [N] T + ptr i32 to fun callees returns UNSAT (solver gap)
// SPEC v0.2.2 §11.1 (multiple -I paths)
// Intention: Scenario B5 -- two -I directories simultaneously. The
// solver resolves @clamp from test/lib/std/scalar and @swap_i32 +
// @array_sum_4_i32 from test/lib/std/collections, then composes them
// with an in-module callee.
decl @clamp(%x: i32, %lo: i32, %hi: i32) : i32;
decl @swap_i32(%a: ptr i32, %b: ptr i32) : i32;
decl @array_sum_4_i32(%p: ptr [4] i32) : i32;

fun @pick_target(%v: i32) : i32 {
  let %ten: i32 = 10;
^entry:
  ret %v + %ten - %ten;
}

fun @main() : i32 {
  sym %?seed: value i32 in [-100, 100];
  let mut %arr: [4] i32 = { 1, 2, 3, 4 };
  let mut %p: ptr [4] i32 = null;
  let mut %a0: ptr i32 = null;
  let mut %a3: ptr i32 = null;
  let mut %lo_val: i32 = 0;
  let mut %clamped: i32 = 0;
  let mut %ret: i32 = 0;
  let mut %sum: i32 = 0;
  let mut %final: i32 = 0;
  let %i0: i32 = 0;
  let %i3: i32 = 3;
  let %lo: i32 = 0;
  let %hi: i32 = 5;
^entry:
  %p = addr %arr;
  // (1) clamp seed into [0, 5]; require result.
  %clamped = call @clamp(%?seed, %lo, %hi);
  require %clamped >= %lo, "clamped >= lo";
  require %clamped <= %hi, "clamped <= hi";
  // Store the clamped result into arr[0].
  %a0 = ptrindex %p, %i0;
  store %a0, %clamped;
  br ^post_clamp;
^post_clamp:
  // (2) swap arr[0] and arr[3].
  %a3 = ptrindex %p, %i3;
  %ret = call @swap_i32(%a0, %a3);
  require %ret == 0, "swap returns 0";
  br ^post_swap;
^post_swap:
  // (3) sum the array; arr is now {4, 2, 3, clamped}.
  %sum = call @array_sum_4_i32(%p);
  require %sum == 9 + %clamped, "sum equals 9 + clamped";
  br ^post_sum;
^post_sum:
  %final = call @pick_target(%sum);
  require %final == %sum, "pick_target identity";
  br ^exit;
^exit:
  ret %clamped;
}
