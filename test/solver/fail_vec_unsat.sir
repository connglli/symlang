// EXPECT: FAIL
// SOLVER_ARGS: --main @main --path '^entry'

// Unsatisfiable: lane 0 of a domain-bounded `[0, 10]` sym cannot
// equal 100. The solver must return UNSAT (path infeasible).
fun @main() : i32 {
  sym %?v: value <4> i32 in [0, 10];
^entry:
  require %?v[0] == 100, "impossible: out of domain";
  ret 0;
}
