// EXPECT: FAIL:StaticError
// SOLVER_ARGS: --main @main --path '^entry'
//
// Rationale: SPEC §3.4.2: Atom-form initializers are only valid for
// non-aggregate types. A struct type (@S) is an aggregate, so initializing
// with a LocalId is forbidden even for 'let mut' bindings.
// Only BraceInit or 'undef' are valid initializers for aggregate types.

struct @S {
  x: i32;
  y: i32;
}

fun @main() : i32 {
  let %s1: @S = {5, 10};
  let mut %s2: @S = %s1;
^entry:
  ret 0;
}
