// EXPECT: PASS
// SOLVER_ARGS: --main @main --path ^entry,^stage1,^stage2,^stage3,^exit
// SKIP: INTERPRETER — contract-form decl is interp-rejected per §11.3
// SKIP: COMPILER — UB only observable via solver SMT reasoning
// SPEC v0.2.2 §7.7 rule 23
// Intention: contract called via initializer assignment of a let mut.
// Pre %k > 0 holds because caller require constrains it positive.
decl @scale(%k: i32) : i32 {
  pre %k > 0, "positive scale";
  post ret >= %k, "non-shrinking";
};

fun @adjust(%x: i32, %y: i32) : i32 {
  let mut %t: i32 = 0;
  let %two: i32 = 2;
  let %one: i32 = 1;
^entry:
  %t = %x + %y;
  br %t > 0, ^pos, ^neg;
^pos:
  %t = %two * %t;
  br %t < 1000, ^cap, ^done;
^cap:
  %t = %t + %one;
  ret %t;
^neg:
  %t = 0 - %t;
  ret %t;
^done:
  ret %t;
}

fun @main() : i32 {
  sym %?k: value i32 in [1, 50];
  sym %?j: value i32 in [1, 50];
  let mut %arr: [4] i32 = {0, 0, 0, 0};
  let mut %s1: i32 = 0;
  let mut %s2: i32 = 0;
  let mut %adj: i32 = 0;
  let mut %final: i32 = 0;
^entry:
  // Initialize via call -- contract called inside the initializer of %s1
  // by appearing on the rhs of an assignment to the let mut local.
  %s1 = call @scale(%?k);
  %arr[0] = %s1;
  %arr[1] = %?j;
  require %s1 >= %?k, "post non-shrinking";
  br %s1 >= 1, ^stage1, ^skip;
^stage1:
  // Second contract call also satisfied.
  %s2 = call @scale(%?j);
  %arr[2] = %s2;
  require %s2 >= %?j, "second post";
  br %s2 >= 1, ^stage2, ^skip;
^stage2:
  %adj = call @adjust(%s1, %s2);
  %arr[3] = %adj;
  require %adj >= 0, "adjust non-negative";
  br %adj >= 0, ^stage3, ^skip;
^stage3:
  %final = %s1 + %s2 + %adj;
  require %final >= 2, "final >= 2";
  br ^exit;
^skip:
  ret 0;
^exit:
  ret %?k;
}
