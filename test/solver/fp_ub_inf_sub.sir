// EXPECT: FAIL:UndefinedBehavior
// SOLVER_ARGS: --main @test --path ^entry
// SKIP: COMPILER
// x < -1.8e38 forces x-1.8e38 to overflow in f32 → -inf: isFinite must be in PC → UNSAT
fun @test() : f32 {
  sym %?x : value f32;
^entry:
  assume %?x < -1.8e38;
  require %?x - 1.8e38 < 0.0;
  ret %?x;
}
