// EXPECT: FAIL:UndefinedBehavior
// SKIP: COMPILER
// SKIP: SOLVER
// SOLVER_ARGS: --main @main --path ^entry,^take_undef

// Reading undef along a specific CFG path is strict UB — solver should prune the path.
fun @main() : i32 {
  sym %?c : value i32;
  let %v: [2] i32 = {10, undef};
^entry:
  br %?c > 0, ^take_undef, ^take_init;
^take_undef:
  ret %v[1];
^take_init:
  ret %v[0];
}
