// EXPECT: FAIL:UndefinedBehavior
// SOLVER_ARGS: --main @main --path '^entry'
//
// Rationale: SPEC §7.5 Rule 14: Relational pointer comparison of different
// objects is UB. Forced cross-object comparison must be UNSAT.

fun @main() : i32 {
  let mut %x: i32 = 1;
  let mut %y: i32 = 2;
  let mut %px: ptr i32 = null;
  let mut %py: ptr i32 = null;
  let mut %res: i1 = 0;
^entry:
  %px = addr %x;
  %py = addr %y;

  // Forced cross-object relational comparison
  %res = cmp < %px, %py;
  ret 0;
}
