// EXPECT: PASS
// SKIP: INTERPRETER, COMPILER
// SOLVER_ARGS: --main @main --path '^entry'
//
// Rationale: SPEC §6.8.10: ptrfield operand is an RValue.
// If the pointer is a field in a struct, it should be reachable.

struct @T {
  f: i32;
}

struct @S {
  p: ptr @T;
}

fun @main() : i32 {
  let mut %t: @T = {42};
  let mut %s: @S = {null};
  let mut %pf: ptr i32 = null;
^entry:
  %s.p = addr %t;

  // %s.p is an RValue with base %s and field access .p.
  // ptrfield should be able to navigate through it.
  %pf = ptrfield %s.p, f;

  require load %pf == 42;
  ret 0;
}
