// EXPECT: PASS
// SOLVER_ARGS: --main @main --path ^entry,^post,^exit
// SKIP: SOLVER -- ptr i32 passed to fun callee + load inside callee returns UNSAT (solver gap)
// SPEC v0.2.2 §9.6.1 + §6.10
// Intention: Scenario A9 (alt) -- helper computes a derived value from
// caller state passed via ptr i32 to a scalar local. Documents an
// open solver gap: even a single `load %p` inside the inlined callee
// drops the connection between the cell's symbolic value and the
// require.
fun @squared_plus(%p: ptr i32, %k: i32) : i32 {
  let mut %v: i32 = 0;
  let mut %sq: i32 = 0;
^entry:
  %v = load %p;
  %sq = %v * %v;
  ret %sq + %k;
}

fun @plus_one(%v: i32) : i32 {
^entry:
  ret %v + 1;
}

fun @main() : i32 {
  sym %?w: value i32 in [0, 10];
  sym %?b: value i32 in [0, 10];
  let mut %cell: i32 = 0;
  let mut %p: ptr i32 = null;
  let mut %r: i32 = 0;
  let mut %r2: i32 = 0;
  let mut %final: i32 = 0;
  let %target: i32 = 41;
^entry:
  %cell = %?w;
  %p = addr %cell;
  %r = call @squared_plus(%p, %?b);
  // r = ?w^2 + ?b = 41, e.g. ?w=6, ?b=5 or ?w=4, ?b=25 (oob), etc.
  require %r == %target, "?w^2 + ?b == 41";
  br ^post;
^post:
  %r2 = call @plus_one(%r);
  require %r2 == 42, "r2 == 42";
  %final = %r2 - 1;
  require %final == %target, "final == target";
  br ^exit;
^exit:
  ret %?w;
}
