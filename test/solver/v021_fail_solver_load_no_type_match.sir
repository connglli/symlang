// EXPECT: FAIL:UndefinedBehavior
// SOLVER_ARGS: --main @main --path '^entry'
//
// Rationale: SPEC §7.5 Rule 11: load through unknown pointer is UB.
// If no local has the matching pointee type, it must be UNSAT/UB.

fun @main() : i32 {
  let mut %x: f32 = 1.0;
  let mut %p: ptr i32 = undef;
  let mut %v: i32 = 0;
^entry:
  %v = load %p; // No i32 locals to point to. Should be UB.
  ret 0;
}
