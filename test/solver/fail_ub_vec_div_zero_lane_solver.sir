// EXPECT: FAIL:UndefinedBehavior
// SOLVER_ARGS: --main @main --path ^entry
// SKIP: INTERPRETER

// Testing Rule 21: Lane-wise scalar UB in solver.
// Division by zero in a single lane should make the whole vector op UB.

fun @main() : i32 {
  let mut %v1: <4> i32 = {10, 10, 10, 10};
  let mut %v2: <4> i32 = {2, 0, 2, 2}; // lane 1 is zero
  let mut %res: <4> i32 = {0, 0, 0, 0};
^entry:
  %res = %v1 / %v2;
  ret 0;
}
