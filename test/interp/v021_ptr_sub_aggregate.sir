// EXPECT: PASS
// Rationale: SPEC §6.8.6: 'ptr T - ptr T' works for aggregate T.

struct @Pair {
  a: i32;
  b: i32;
}

fun @main() : i32 {
  let mut %arr: [10] @Pair = 0;
  let mut %p: ptr @Pair = null;
  let mut %q: ptr @Pair = null;
  let mut %diff: i64 = 0;
^entry:
  %p = addr %arr[0];
  %q = addr %arr[5];

  %diff = %q - %p; // Should be 5
  require %diff == 5;
  ret 0;
}
