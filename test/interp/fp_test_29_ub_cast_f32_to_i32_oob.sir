// EXPECT: FAIL:UndefinedBehavior
// SKIP: WASM
// Reason: WASM doesn't support ASan/UBSan style runtime trapping for float-to-int out-of-range casts.
// Intention: Test UB for out-of-bounds float-to-integer cast (positive boundary).
// Purpose: Verify that casting a float value greater than or equal to the maximum representable i32 value is flagged as Undefined Behavior (SPEC Rule 8).
// f32 3.4e38 cast to i32: out of i32 range [-2^31, 2^31-1], UB rule 8
fun @main() : i32 {
  let %a: f32 = 3.4e38;
  let mut %r: i32 = 0;
^entry:
  %r = %a as i32;
  ret %r;
}
