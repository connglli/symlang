// EXPECT: FAIL
// SKIP: SOLVER, COMPILER, INTERPRETER
//
// Rule 15b typed-access mismatch. `addr %t.a` gives ptr i32 with
// provenance = struct @T. Advancing by 1 element lands on field b
// (i64). Loading i32 from an i64 cell is UB per rule 15b.
// The interpreter doesn't yet validate that the runtime offset
// coincides with a T-typed cell — it only checks bounds. Re-enable
// when rule 15b typed-access validation is implemented.
// Exposes: Incorrect UB detection (aborts with wrong UB reason).
// Expected Behavior: symiri aborts with exit code 5 (UB: Typed-access mismatch).
// Actual Behavior: symiri aborts with wrong error "UB: Load out of bounds" instead.

struct @T { a: i32; b: i64; }

fun @main() : i32 {
  let mut %t: @T = {10, 20};
  let mut %pa: ptr i32 = null;
^entry:
  %pa = addr %t.a;
  %pa = %pa + 1; // pa points to offset 4 (t.b, which is i64)
  ret load %pa;  // UB: typed-access mismatch!
}
