// EXPECT: PASS
fun @main(): i32 {
    let mut %arr: [2] [4] i32 = {{1, 2, 3, 4}, {5, 6, 7, 8}};
    let mut %p: ptr [4] i32 = null;
    let mut %p2: ptr [4] i32 = null;
    let mut %elem: ptr i32 = null;
    let mut %val: i32 = 0;

    ^entry:
        %p = addr %arr[0];
        %p2 = %p + 1; // points to arr[1]
        %elem = ptrindex %p2, 0; // should be arr[1][0] = 5
        %val = load %elem;
        // Currently buggy interpreter returns arr[0][0] = 1
        // because it uses obj->base instead of ptrRv.ptrVal.
        ret %val;
}
