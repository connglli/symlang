// EXPECT: PASS
// SKIP: WASM — WASM backend bug with vector pass-by-value through `call` (see H_vec_pass)
// INTERP_ARGS: -I test/lib/std/simd
// COMPILER_ARGS: -I test/lib/std/simd
// SPEC v0.2.2 §11.3
decl @reduce_min_4_i32(%v: <4> i32) : i32;
decl @reduce_max_4_i32(%v: <4> i32) : i32;
decl @broadcast_4_i32(%x: i32) : <4> i32;

fun @sub(%a: i32, %b: i32) : i32 {
^entry:
  ret %a - %b;
}

fun @main() : i32 {
  let mut %v: <4> i32 = { -3, 7, 2, 9 };
  let mut %mn: i32 = 0;
  let mut %mx: i32 = 0;
  let mut %bc: <4> i32 = { 0, 0, 0, 0 };
  let mut %h: i32 = 0;
  let mut %t: i32 = 0;
  let %z: i32 = 0;
  let %o: i32 = 1;
^entry:
  %mn = call @reduce_min_4_i32(%v); // -3
  %mx = call @reduce_max_4_i32(%v); // 9
  %t = %mx + %mn;
  br %mn == -3, ^b1, ^bad;
^b1:
  %bc = call @broadcast_4_i32(5);
  %t = %bc[0] + %bc[3]; // 10
  %t = %t + %z;
  br %mx == 9, ^b2, ^bad;
^b2:
  %h = call @sub(%mx, %mn); // 12
  %t = %h - %t;
  %t = %t + %z;
  br %h == 12, ^b3, ^bad;
^b3:
  %t = %t + %z;
  %t = %t - %z;
  %t = %t + %z;
  br %t == 2, ^ok, ^bad;
^ok:
  ret %z;
^bad:
  ret %o;
}
