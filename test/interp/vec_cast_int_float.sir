// EXPECT: PASS

// Lane-wise int<->float casts.
fun @main() : i32 {
  let %i: <4> i32 = {-3, 0, 5, 1000000};
  let %f: <4> f32 = {-1.7, 0.0, 2.5, 9.99};
  let mut %if: <4> f32 = 0.0;
  let mut %fi: <4> i32 = 0;
^entry:
  %if = %i as <4> f32;       // i32 -> f32, lane-wise (RNE)
  %fi = %f as <4> i32;       // f32 -> i32, lane-wise (truncation toward zero)
  require %if[2] == 5.0,  "5 -> 5.0";
  require %fi[2] == 2,    "2.5 -> 2 (RTZ)";
  require %fi[0] == -1,   "-1.7 -> -1 (RTZ)";
  ret 0;
}
