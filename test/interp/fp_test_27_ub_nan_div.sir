// EXPECT: FAIL:UndefinedBehavior
// Intention: Test UB for float operations producing NaN.
// Purpose: Verify that float operations that yield NaN (e.g. 0.0 / 0.0) are flagged as Undefined Behavior (SPEC Rule 7).
// f32 0.0 / 0.0 produces NaN: UB rule 7
fun @main() : f32 {
  let %a: f32 = 0.0;
  let %b: f32 = 0.0;
  let mut %r: f32 = 0.0;
^entry:
  %r = %a / %b;
  ret %r;
}
