// EXPECT: PASS
// 3.5 % 2.0: quotient = 1.75, RNE rounds to 2, result = 3.5 - 2*2.0 = -0.5
// fmod gives 1.5 (truncates quotient to 1).
fun @main() : f32 {
  let %a: f32 = 3.5;
  let %b: f32 = 2.0;
  let %expected: f32 = -0.5;
  let mut %r: f32 = 0.0;
^entry:
  %r = %a % %b;
  require %r == %expected, "3.5 rem 2.0 == -0.5";
  ret %r;
}
