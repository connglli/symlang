// EXPECT: PASS
// INTERP_ARGS: -I test/lib/std/collections
decl @array_sum_4_i32(%p: ptr [4] i32) : i32;

fun @main() : i32 {
  let mut %a: [4] i32 = {10, 20, 30, 40};
  let mut %p: ptr [4] i32 = null;
  let mut %s: i32 = 0;
^entry:
  %p = addr %a;
  %s = call @array_sum_4_i32(%p);
  require %s == 100, "array_sum 10+20+30+40";
  ret 0;
}
