// EXPECT: PASS
// Three-pointer merge step: merge two sorted 4-element arrays into output.
// left={1,3,5,7}, right={2,4,6,8} -> out={1,2,3,4,5,6,7,8}
// Core of merge sort; uses lp/rp advancing over inputs and op advancing over output.
fun @main() : i32 {
  let mut %left: [4] i32 = {1, 3, 5, 7};
  let mut %right: [4] i32 = {2, 4, 6, 8};
  let mut %out: [8] i32 = {0, 0, 0, 0, 0, 0, 0, 0};
  let mut %lp: ptr i32 = null;
  let mut %rp: ptr i32 = null;
  let mut %op: ptr i32 = null;
  let %one: i32 = 1;
  let mut %li: i32 = 0;
  let mut %ri: i32 = 0;
  let mut %lv: i32 = 0;
  let mut %rv: i32 = 0;
  let mut %v: i32 = 0;
^entry:
  %lp = addr %left[0];
  %rp = addr %right[0];
  %op = addr %out[0];
  br ^merge_check;

^merge_check:
  // if left exhausted, flush right; if right exhausted, flush left
  br %li < 4, ^check_r, ^flush_right;

^check_r:
  br %ri < 4, ^merge_cmp, ^flush_left;

^merge_cmp:
  %lv = load %lp;
  %rv = load %rp;
  br %lv <= %rv, ^take_left, ^take_right;

^take_left:
  store %op, %lv;
  %lp = %lp + %one;
  %op = %op + %one;
  %li = %li + 1;
  br ^merge_check;

^take_right:
  store %op, %rv;
  %rp = %rp + %one;
  %op = %op + %one;
  %ri = %ri + 1;
  br ^merge_check;

^flush_left:
  br %li < 4, ^do_flush_left, ^verify;

^do_flush_left:
  store %op, load %lp;
  %lp = %lp + %one;
  %op = %op + %one;
  %li = %li + 1;
  br ^flush_left;

^flush_right:
  br %ri < 4, ^do_flush_right, ^verify;

^do_flush_right:
  store %op, load %rp;
  %rp = %rp + %one;
  %op = %op + %one;
  %ri = %ri + 1;
  br ^flush_right;

^verify:
  %op = addr %out[0];
  %v = load %op;
  require %v == 1, "out[0]==1";
  %op = %op + %one;
  %v = load %op;
  require %v == 2, "out[1]==2";
  %op = %op + %one;
  %v = load %op;
  require %v == 3, "out[2]==3";
  %op = %op + %one;
  %v = load %op;
  require %v == 4, "out[3]==4";
  %op = %op + %one;
  %v = load %op;
  require %v == 5, "out[4]==5";
  %op = %op + %one;
  %v = load %op;
  require %v == 6, "out[5]==6";
  %op = %op + %one;
  %v = load %op;
  require %v == 7, "out[6]==7";
  %op = %op + %one;
  %v = load %op;
  require %v == 8, "out[7]==8";
  ret 0;
}
