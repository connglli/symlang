// EXPECT: FAIL:UndefinedBehavior
// SKIP: WASM
// INTERP_ARGS: --sym %?a=2147483647 --sym %?b=1
// COMPILER_ARGS: --sym %?a=2147483647 --sym %?b=1

// Signed integer overflow (MAX_INT32 + 1) is strict UB.
fun @main() : i32 {
  sym %?a : value i32;
  sym %?b : value i32;
  let mut %x: i32 = 0;
  let mut %y: i32 = 0;
^entry:
  %x = %?a;
  %y = %?b;
  ret %x + %y;
}
