// EXPECT: PASS
// SKIP: COMPILER
// SKIP: SOLVER
// Per spec rule 15: `addr %s.a` gives provenance = the whole struct @Pair.
// Advancing by 1 element lands on field 'b' (also i32). The load is valid
// per rule 15b (the offset coincides with a T-typed cell). Result = 20.
struct @Pair { a: i32; b: i32; }

fun @main() : i32 {
  let mut %s: @Pair = {10, 20};
  let mut %pa: ptr i32 = null;
  let %one: i32 = 1;
  let mut %v: i32 = 0;
^entry:
  %pa = addr %s.a;
  %pa = %pa + %one;
  %v = load %pa;
  require %v == 20, "should read field b";
  ret 0;
}
