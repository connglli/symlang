// EXPECT: FAIL:UndefinedBehavior
// SKIP: WASM
// Reason: WASM doesn't support ASan/UBSan style runtime trapping for signed integer multiplication overflow.
// INTERP_ARGS: --sym %?a=-2147483648
// COMPILER_ARGS: --sym %?a=-2147483648

// Signed overflow (MIN_INT32 * -1) is strict UB.
fun @main() : i32 {
  sym %?a : value i32;
  let %neg_one: i32 = -1;
  let mut %x: i32 = 0;
^entry:
  %x = %?a;
  ret %x * %neg_one;
}
