// EXPECT: PASS
// 5.5 % 2.0: quotient = 2.75, RNE rounds to 3, result = 5.5 - 3*2.0 = -0.5
// fmod gives 1.5 (truncates quotient to 2).
fun @main() : f32 {
  let %a: f32 = 5.5;
  let %b: f32 = 2.0;
  let %expected: f32 = -0.5;
  let mut %r: f32 = 0.0;
^entry:
  %r = %a % %b;
  require %r == %expected, "5.5 rem 2.0 == -0.5";
  ret %r;
}
