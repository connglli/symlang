// EXPECT: PASS
// 3.5 % 2.0 (f32): fmod truncates quotient to 1, result = 3.5 - 1*2.0 = 1.5
// (IEEE remainder gives -0.5 since it rounds quotient to 2)
fun @main() : f32 {
  let %a: f32 = 3.5;
  let %b: f32 = 2.0;
  let %expected: f32 = 1.5;
  let mut %r: f32 = 0.0;
^entry:
  %r = %a % %b;
  require %r == %expected, "3.5 fmod 2.0 == 1.5";
  ret %r;
}
