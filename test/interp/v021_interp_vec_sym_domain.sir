// EXPECT: PASS
// INTERP_ARGS: --sym %?v=10
// Rationale: Testing sym vector domain in interpreter.

fun @main() : i32 {
  sym %?v: value <2> i32 in [10, 10];
  let mut %v: <2> i32 = %?v;
  let mut %v0: i32 = 0;
  let mut %v1: i32 = 0;
^entry:
  %v0 = %v[0];
  %v1 = %v[1];
  ret %v0 + %v1; // Should return 20
}
