// EXPECT: FAIL:UndefinedBehavior
// SKIP: WASM
// Reason: WASM doesn't support ASan/UBSan style runtime trapping for pointer subtraction across different objects.
// Rationale: SPEC §7.5 Rule 12: 'ptr T - ptr T' with different objects is UB.

fun @main() : i32 {
  let mut %a: i32 = 1;
  let mut %b: i32 = 2;
  let mut %pa: ptr i32 = null;
  let mut %pb: ptr i32 = null;
  let mut %diff: i64 = 0;
^entry:
  %pa = addr %a;
  %pb = addr %b;
  %diff = %pa - %pb; // UB
  ret 0;
}
