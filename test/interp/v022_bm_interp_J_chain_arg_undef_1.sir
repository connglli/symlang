// EXPECT: FAIL:UndefinedBehavior
// SKIP: WASM — WASM runtime cannot detect undef propagation through call args (SymIR-specific UB)
// SKIP: COMPILER — undef propagation through call args is SymIR-specific; C runtime cannot reproduce
// SPEC v0.2.2 §7.1 rule 3 - undef passed into a chain
intrinsic @abs(%x: i32) : i32;
fun @main() : i32 {
  let mut %u: i32 = undef;
  let mut %r: i32 = 0;
^entry:
  %r = call @abs(%u + 1); // reads undef
  ret %r;
}
