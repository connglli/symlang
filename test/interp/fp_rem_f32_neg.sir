// EXPECT: PASS
// -1.5 % 1.0: quotient = -1.5, RNE rounds to -2, result = -1.5 - (-2)*1.0 = 0.5
// fmod gives -0.5 (truncates quotient to -1).
fun @main() : f32 {
  let %a: f32 = -1.5;
  let %b: f32 = 1.0;
  let %expected: f32 = 0.5;
  let mut %r: f32 = 0.0;
^entry:
  %r = %a % %b;
  require %r == %expected, "-1.5 rem 1.0 == 0.5";
  ret %r;
}
