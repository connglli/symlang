// EXPECT: FAIL:UndefinedBehavior
// SKIP: WASM — WASM runtime has no UBSan-equivalent for reading undef values
// SKIP: COMPILER — callee-undef-read UB is SymIR-specific; C UBSan does not detect every undef path
// SPEC v0.2.2 §7.1 rule 3
// Intention: callee loads from a let mut left as undef -> UB.
fun @read(%p: ptr i32) : i32 {
^entry:
  ret load %p;
}
fun @main() : i32 {
  let mut %u: i32 = undef;
^entry:
  ret call @read(addr %u);
}
