// EXPECT: PASS

// Whole-vector copy `%v = %w;` (§6.6). Subsequent lane writes to %v must
// not affect %w (independent storage).
fun @main() : i32 {
  let %src: <4> i32 = {10, 20, 30, 40};
  let mut %dst: <4> i32 = 0;
^entry:
  %dst = %src;
  %dst[0] = 99;             // modify copy only
  require %src[0] == 10, "src untouched";
  require %dst[0] == 99, "dst mutated";
  require %dst[3] == 40, "dst other lanes preserved";
  ret 0;
}
