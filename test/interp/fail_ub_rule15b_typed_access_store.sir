// EXPECT: FAIL:UndefinedBehavior
// SKIP: SOLVER, COMPILER, INTERPRETER
//
// Rule 15b typed-access mismatch on store. The interpreter doesn't yet
// validate that the runtime offset coincides with a T-typed cell.
// Re-enable when rule 15b is implemented in the interpreter.
// Expected Behavior: Interpreter aborts with typed-access mismatch UB.
// Actual Behavior: Interpreter succeeds and exits with 0.

struct @T { a: i32; b: i64; }

fun @main() : i32 {
  let mut %t: @T = {10, 20};
  let mut %pa: ptr i32 = null;
^entry:
  %pa = addr %t.a;
  %pa = %pa + 1; // pa points to offset 4 (t.b, which is i64)
  // Store i32 value into i64 cell - UB typed-access mismatch!
  store %pa, 42;
  ret 0;
}
