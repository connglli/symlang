// EXPECT: FAIL:UndefinedBehavior
// SKIP: WASM
// Reason: WASM doesn't support ASan/UBSan style runtime trapping for bitwise overshifts.
// INTERP_ARGS: --sym %?n=32
// COMPILER_ARGS: --sym %?n=32

// Shifting a 32-bit value by its own width (32) is strict UB.
fun @main() : i32 {
  sym %?n : value i32;
  let %x: i32 = 1;
  let mut %amount: i32 = 0;
  let mut %y: i32 = 0;
^entry:
  %amount = %?n;
  %y = %x << %amount;
  ret %y;
}
