// EXPECT: PASS
// In-place prefix sum (scan) via two-pointer walk.
// Input: {1,2,3,4,5,6}  Output: {1,3,6,10,15,21}
// Classic streaming algorithm: each element becomes the running total.
fun @main() : i32 {
  let mut %arr: [6] i32 = {1, 2, 3, 4, 5, 6};
  let mut %cur: ptr i32 = null;
  let mut %prv: ptr i32 = null;
  let %one: i32 = 1;
  let mut %i: i32 = 1;
  let mut %v: i32 = 0;
  let mut %s: i32 = 0;
^entry:
  %prv = addr %arr[0];
  %cur = addr %arr[1];
  br ^loop;

^loop:
  br %i < 6, ^body, ^verify;

^body:
  %v = load %cur;
  %s = load %prv;
  store %cur, %v + %s;
  %prv = %cur;
  %cur = %cur + %one;
  %i = %i + 1;
  br ^loop;

^verify:
  %cur = addr %arr[0];
  %v = load %cur;
  require %v == 1, "arr[0]==1";
  %cur = %cur + %one;
  %v = load %cur;
  require %v == 3, "arr[1]==3";
  %cur = %cur + %one;
  %v = load %cur;
  require %v == 6, "arr[2]==6";
  %cur = %cur + %one;
  %v = load %cur;
  require %v == 10, "arr[3]==10";
  %cur = %cur + %one;
  %v = load %cur;
  require %v == 15, "arr[4]==15";
  %cur = %cur + %one;
  %v = load %cur;
  require %v == 21, "arr[5]==21";
  ret 0;
}
