// EXPECT: PASS
// -3.5 % 2.0 (f64): fmod truncates quotient to -1, result = -3.5 - (-1)*2.0 = -1.5
// (IEEE remainder gives 0.5 since it rounds quotient to -2)
fun @main() : f64 {
  let %a: f64 = -3.5;
  let %b: f64 = 2.0;
  let %expected: f64 = -1.5;
  let mut %r: f64 = 0.0;
^entry:
  %r = %a % %b;
  require %r == %expected, "-3.5 fmod 2.0 (f64) == -1.5";
  ret %r;
}
