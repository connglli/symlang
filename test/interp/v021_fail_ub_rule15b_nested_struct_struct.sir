// EXPECT: FAIL:UndefinedBehavior
// SKIP: COMPILER
// Rationale: This test demonstrates that the interpreter fails to recursively
// create field-level ObjectInfos for nested structs (struct within struct).
// Expected behavior: UB (Typed-access mismatch).
// Observed behavior: PASS (Interpreter misses the nested field ObjectInfo).

struct @Inner {
  f1: i32;
  val: i64;
}

struct @Outer {
  inner: @Inner;
}

fun @main() : i32 {
  let mut %o: @Outer = {{1, 10}};
  let mut %pi: ptr @Inner = null;
  let mut %pf: ptr i32 = null;
  let mut %p_alias: ptr i32 = null;
  let mut %v: i32 = 0;
^entry:
  %pi = addr %o.inner;
  %pf = ptrfield %pi, f1;
  %p_alias = %pf + 2;
  %v = load %p_alias;
  ret %v;
}
