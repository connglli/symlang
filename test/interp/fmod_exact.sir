// EXPECT: PASS
// 7.0 % 3.5: exact division, quotient = 2, result = 7.0 - 2*3.5 = 0.0
// fmod and remainder agree when quotient is exact integer
fun @main() : f64 {
  let %a: f64 = 7.0;
  let %b: f64 = 3.5;
  let %expected: f64 = 0.0;
  let mut %r: f64 = 0.0;
^entry:
  %r = %a % %b;
  require %r == %expected, "7.0 fmod 3.5 == 0.0";
  ret %r;
}
