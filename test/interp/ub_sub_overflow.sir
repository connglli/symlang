// EXPECT: FAIL:UndefinedBehavior
// SKIP: WASM
// INTERP_ARGS: --sym %?a=-2147483648
// COMPILER_ARGS: --sym %?a=-2147483648

// Signed underflow (MIN_INT32 - 1) is strict UB.
fun @main() : i32 {
  sym %?a : value i32;
  let %one: i32 = 1;
  let mut %x: i32 = 0;
^entry:
  %x = %?a;
  ret %x - %one;
}
