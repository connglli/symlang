// EXPECT: PASS
// SKIP: WASM — WASM backend lowers `<N> T` as a stack pointer; passing it through `call` triggers a stack-type mismatch (real backend bug)
// SPEC v0.2.2 §2.12 vector ret then lane access
fun @double_v(%v: <4> i32) : <4> i32 {
  let mut %r: <4> i32 = { 0, 0, 0, 0 };
^entry:
  %r[0] = %v[0] + %v[0];
  %r[1] = %v[1] + %v[1];
  %r[2] = %v[2] + %v[2];
  %r[3] = %v[3] + %v[3];
  ret %r;
}
fun @main() : i32 {
  let mut %v: <4> i32 = { 1, 2, 3, 4 };
  let mut %r: <4> i32 = { 0, 0, 0, 0 };
  let mut %s: i32 = 0;
^entry:
  %r = call @double_v(%v);
  %s = %r[0] + %r[1] + %r[2] + %r[3]; // 2+4+6+8=20
  br %s == 20, ^ok, ^bad;
^ok:
  ret 0;
^bad:
  ret 1;
}
