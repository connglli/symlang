// EXPECT: PASS

// Lane-wise vector addition. Returns the sum of all lanes of the result.
fun @main() : i32 {
  let %a: <4> i32 = {1, 2, 3, 4};
  let %b: <4> i32 = {10, 20, 30, 40};
  let mut %c: <4> i32 = 0;
  let mut %s: i32 = 0;
^entry:
  %c = %a + %b;                  // {11, 22, 33, 44}
  %s = %c[0] + %c[1] + %c[2] + %c[3];
  require %s == 110, "sum_lanes";
  ret %s;
}
