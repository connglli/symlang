// EXPECT: PASS

// `cmp` produces `<N> i1`; mask-based `select` blends per-lane.
fun @main() : i32 {
  let %a: <4> i32 = { 3, -5, 7, -1};
  let %z: <4> i32 = 0;
  let mut %mask: <4> i1 = 0;
  let mut %r: <4> i32 = 0;
^entry:
  %mask = cmp < %a, %z;          // {0, 1, 0, 1}
  %r    = select %mask, %z, %a;  // replace negative lanes with 0: {3, 0, 7, 0}
  require %r[0] == 3, "pos lane 0 unchanged";
  require %r[1] == 0, "neg lane 1 -> 0";
  require %r[3] == 0, "neg lane 3 -> 0";
  ret 0;
}
