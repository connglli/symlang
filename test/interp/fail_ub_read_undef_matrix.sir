// EXPECT: FAIL:UndefinedBehavior
// INTERP_ARGS: --sym %?m00=0 --sym %?m01=-1 --sym %?m10=1 --sym %?m11=0
struct @Matrix2x2 {
  data: [2][2] i8;  // 2x2 grid storing matrix elements in [row][col] order
}

struct @Vector2 {
  data: [2] i8;     // 2-element array representing a 2D vector [x, y]
}

fun @main() : i32 {
  sym %?m00 : value i8 in [-2, 2];
  sym %?m01 : value i8 in [-2, 2];
  sym %?m10 : value i8 in [-2, 2];
  sym %?m11 : value i8 in [-2, 2];

  let mut %M: @Matrix2x2 = undef;
  let mut %x: @Vector2 = undef;
  let mut %y: @Vector2 = undef;

  let mut %m00_v: i8 = 0;
  let mut %m01_v: i8 = 0;
  let mut %m10_v: i8 = 0;
  let mut %m11_v: i8 = 0;

  let mut %r0c0: i8 = 0;
  let mut %r0c1: i8 = 0;
  let mut %r1c0: i8 = 0;
  let mut %r1c1: i8 = 0;

  let mut %y0_v: i8 = 0;
  let mut %y1_v: i8 = 0;
  let mut %y0_32: i32 = 0;
  let mut %y1_32: i32 = 0;
  let mut %ret: i32 = 0;

^entry:
  // --- 2. Load Matrix and Vector ---
  // UB: We read %M.data[0][0] before it's assigned.
  // We'll skip assigning %M.data[0][0] and read it below.
  // %M.data[0][0] = %?m00;
  %M.data[0][1] = %?m01;
  %M.data[1][0] = %?m10;
  %M.data[1][1] = %?m11;

  %x.data[0] = 1;
  %x.data[1] = 0;

  br ^multiply;

^multiply:
  // Load row elements into simple locals to use as coefficients
  %m00_v = %M.data[0][0]; // UB: reads undef
  %m01_v = %M.data[0][1];
  %m10_v = %M.data[1][0];
  %m11_v = %M.data[1][1];

  %r0c0 = %m00_v * %x.data[0];
  %r0c1 = %m01_v * %x.data[1];
  %y.data[0] = %r0c0 + %r0c1;

  %r1c0 = %m10_v * %x.data[0];
  %r1c1 = %m11_v * %x.data[1];
  %y.data[1] = %r1c0 + %r1c1;

  br ^exit;

^exit:
  require %y.data[0] == 0, "Target x-component must be 0";
  require %y.data[1] == 1, "Target y-component must be 1";

  %y0_v = %y.data[0];
  %y1_v = %y.data[1];
  %y0_32 = %y0_v as i32;
  %y1_32 = %y1_v as i32;
  %ret = 10 * %y0_32 + %y1_32;
  ret %ret;
}
