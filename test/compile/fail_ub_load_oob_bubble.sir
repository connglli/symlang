// EXPECT: FAIL:UndefinedBehavior
// SKIP: INTERPRETER
// COMPILER_ARGS: --sym %?missing=3

// Mutated from bubble_sort.sir
// Triggers Rule 11: Out-of-bounds load in compiled code via pointers.

fun @main() : i32 {
  sym %?missing : value i32 in [0, 10];
  let mut %arr: [4] i32 = {1, 2, 3, 4};
  let mut %p: ptr i32 = null;
  let mut %val: i32 = 0;
^entry:
  %p = addr %arr[0];
  %p = %p + 4; // one-past-end
  %val = load %p; // UB
  ret %val;
}
