// EXPECT: PASS
// COMPILER_ARGS: --target c
fun @main(): i32 {
    let mut %arr: [4] i32 = {1, 2, 3, 4};
    // v0.2.1 §3.2: PointeeType can be ArrayType.
    // C backend currently emits int32_t * instead of int32_t (*)[4],
    // causing a type mismatch error when assigning addr %arr.
    let mut %p: ptr [4] i32 = null;
    ^entry:
        %p = addr %arr;
        ret 0;
}
