// EXPECT: FAIL:UndefinedBehavior
// SKIP: INTERPRETER
// COMPILER_ARGS: --sym %?missing=3
// SKIP: WASM
// Reason: WASM doesn't support ASan/UBSan style runtime trapping for cross-object pointer comparisons.

// Mutated from bubble_sort.sir
// Tests cross-object pointer arithmetic in compiled code.
// Rule 12: Cross-object pointer arithmetic is UB.

struct @SortContext {
  data: [4] i32;
  i: i32;
  j: i32;
  n: i32;
  swapped: i1;
}

fun @main() : i32 {
  sym %?missing : value i32 in [0, 10];
  let mut %ctx: @SortContext = 0;
  let mut %other: i32 = 0;
  let mut %p: ptr i32 = null;
^entry:
  %p = addr %other;
  // Arithmetic that should land in %ctx if objects were adjacent, but it's UB.
  %p = %p + 1;
  %other = load %p;
  ret %other;
}
