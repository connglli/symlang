// EXPECT: PASS
// 5.0 % -3.0 (f32): fmod = 2.0 (sign of result matches dividend, not divisor)
// trunc(5/-3) = trunc(-1.666) = -1; 5 - (-1)*(-3) = 5 - 3 = 2
fun @main() : f32 {
  let %a: f32 = 5.0;
  let %b: f32 = -3.0;
  let %expected: f32 = 2.0;
  let mut %r: f32 = 0.0;
^entry:
  %r = %a % %b;
  require %r == %expected, "5.0 fmod -3.0 == 2.0";
  ret %r;
}
