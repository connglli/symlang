// EXPECT: PASS
// EXPECT_RC: 24
// i32 -> f32 -> i32 round-trip with arithmetic in the middle.
// Tests that lane-wise FP RNE rounding agrees with the C backend's
// emission under FLT_EVAL_METHOD == 0.
fun @main() : i32 {
  let %i: <4> i32 = {3, 5, 7, 9};
  let mut %f: <4> f32 = 0.0;
  let mut %g: <4> f32 = 0.0;
  let mut %r: <4> i32 = 0;
^entry:
  %f = %i as <4> f32;       // {3.0, 5.0, 7.0, 9.0}
  %g = %f * %f;             // {9.0, 25.0, 49.0, 81.0}
  %g = 0.1 * %g;            // {0.9, 2.5, 4.9, 8.1}
  %r = %g as <4> i32;       // {0, 2, 4, 8} (truncation toward zero)
  ret %r[0] + %r[1] + %r[2] + %r[3] + 10;   // 14 + 10 = 24
}
