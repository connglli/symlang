// EXPECT: PASS
// EXPECT_RC: 41
// Round-trips integers through f64 and back, plus uses branching inside the
// loop based on a fp comparison. For each k in [0, 8):
//   d = k as f64
//   d = d * d            (square)
//   d = d / 3.0          (divide; may round)
//   if d >= 5.0:
//     count += (i32)d    (fp -> int truncation toward zero)
// Final return is count.
//
// Exercises:
//   - int -> f64 cast
//   - f64 mul + div
//   - fp comparison driving branch
//   - f64 -> i32 truncation (RTZ)
//   - int loop counter + accumulator
//   - 6 blocks: ^entry, ^check, ^body, ^if_taken, ^if_not, ^done (loop has
//     a back-edge to ^check).
//
// Manual:
//   k=0: d=0, 0/3=0,    skip
//   k=1: d=1, 1/3=0.333,skip
//   k=2: d=4, 4/3=1.33, skip
//   k=3: d=9, 9/3=3.0,  skip (< 5.0)
//   k=4: d=16,16/3=5.33,take → count += 5 → count=5
//   k=5: d=25,25/3=8.33,take → count += 8 → count=13
//   k=6: d=36,36/3=12,  take → count += 12 → count=25
//   k=7: d=49,49/3=16.33,take→ count += 16 → count=41
// Hmm: actual run determines what we ACTUALLY get; the EXPECT pins it.
fun @main() : i32 {
  let mut %k: i32 = 0;
  let mut %count: i32 = 0;
  let mut %d: f64 = 0.0;
  let mut %trunc: i32 = 0;
  let mut %three: f64 = 3.0;
^entry:
  br ^check;
^check:
  br %k < 8, ^body, ^done;
^body:
  %d = %k as f64;
  %d = %d * %d;
  %d = %d / %three;
  br %d >= 5.0, ^if_taken, ^if_not;
^if_taken:
  %trunc = %d as i32;
  %count = %count + %trunc;
  br ^if_next;
^if_not:
  br ^if_next;
^if_next:
  %k = %k + 1;
  br ^check;
^done:
  ret %count;
}
