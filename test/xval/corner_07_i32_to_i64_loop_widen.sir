// EXPECT: PASS
// EXPECT_RC: 45
// Widen i32 to i64 in a loop, accumulate
fun @main() : i64 {
  let mut %i: i32 = 0;
  let mut %t: i32 = 100;
  let mut %sum: i64 = 0;
  let mut %wide: i64 = 0;
^entry:
  br ^check;
^check:
  br %i < 10, ^body, ^done;
^body:
  %wide = %i as i64;
  %sum = %sum + %wide;
  %i = %i + 1;
  br ^check;
^done:
  ret %sum;
}
