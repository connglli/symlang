// EXPECT: PASS
// EXPECT_RC: 30
// Big xval test 23 — Frobenius inner product of two 3x3 i32 matrices,
// accumulated as f64, returned as i32. Nested struct tracks per-diag
// contribution. Block 3 casts:  i32 -> i16 -> f32 -> f64.
struct @Diag23 {
  vals: [3] i32;
  contrib: f64;
}
struct @Frob23 {
  diag: @Diag23;
  total: f64;
}

fun @main() : i32 {
  let mut %a: [3] [3] i32 = {{1, 2, 3}, {4, 5, 6}, {7, 8, 9}};
  let mut %b: [3] [3] i32 = {{1, 0, 1}, {0, 2, 0}, {1, 0, 1}};
  let mut %fr: @Frob23 = {{{0, 0, 0}, 0.0}, 0.0};
  let mut %running: f64 = 0.0;
  let mut %p_run: ptr f64 = undef;
  let mut %i: i32 = 0;
  let mut %j: i32 = 0;
  let mut %ai: i32 = 0;
  let mut %bi: i32 = 0;
  let mut %prod: i32 = 0;
  let mut %tmp_i16: i16 = 0;
  let mut %tmp_f32: f32 = 0.0;
  let mut %tmp_f64: f64 = 0.0;
^entry:
  %running = 0.0;
  %p_run = addr %running;
  %i = 0;
  %j = 0;
  store %p_run, %running;
  %prod = 0;
  br ^pre1;
^pre1:
  %ai = 10;
  %tmp_i16 = %ai as i16;
  %tmp_f32 = %tmp_i16 as f32;
  %tmp_f64 = %tmp_f32 as f64;
  %prod = %ai * %ai;
  %prod = 0;
  br ^pre2;
^pre2:
  %ai = 5;
  %tmp_i16 = %ai as i16;
  %tmp_f32 = %tmp_i16 as f32;
  %tmp_f64 = %tmp_f32 as f64;
  %prod = 0;
  %bi = 0;
  br ^head;
^head:
  %j = 0;
  %ai = 0;
  %bi = 0;
  %prod = 0;
  %tmp_i16 = %i as i16;
  %tmp_f32 = %i as f32;
  br %i < 3, ^inner_head, ^post;
^inner_head:
  %ai = 0;
  %bi = 0;
  %prod = 0;
  %tmp_i16 = %j as i16;
  %tmp_f32 = %j as f32;
  %tmp_f64 = %tmp_f32 as f64;
  br %j < 3, ^inner_body, ^outer_step;
^inner_body:
  %ai = %a[%i][%j];
  %bi = %b[%i][%j];
  %prod = %ai * %bi;
  %tmp_f32 = %prod as f32;
  %tmp_f64 = %tmp_f32 as f64;
  %running = %running + %tmp_f64;
  br ^inner_step;
^inner_step:
  store %p_run, %running;
  %j = %j + 1;
  %tmp_f64 = load %p_run;
  %running = %tmp_f64 + 0.0;
  %tmp_i16 = %j as i16;
  %tmp_f32 = %j as f32;
  br ^inner_head;
^outer_step:
  %fr.diag.vals[%i] = %prod;
  %i = %i + 1;
  %tmp_f64 = load %p_run;
  %running = %tmp_f64 + 0.0;
  %tmp_i16 = %i as i16;
  %tmp_f32 = %i as f32;
  br ^head;
^post:
  %tmp_f64 = load %p_run;
  %fr.total = %tmp_f64 + 0.0;
  %fr.diag.contrib = %tmp_f64 + 0.0;
  %tmp_f32 = %tmp_f64 as f32;
  %tmp_i16 = %tmp_f32 as i16;
  %prod = %tmp_i16 as i32;
  br ^exit;
^exit:
  %tmp_f64 = %fr.total + 0.0;
  %tmp_f32 = %tmp_f64 as f32;
  %tmp_i16 = %tmp_f32 as i16;
  %prod = %tmp_i16 as i32;
  %ai = %fr.diag.vals[0];
  %bi = %b[2][2];
  ret %prod;
}
