// EXPECT: PASS
// EXPECT_RC: 0x1.dp+4
// Big xval test 12 — Matrix-vector product. 2D array %m (3x4) of i32 times
// f32 vector %v (length 4); per-row partial sum stored into nested-struct
// %st row/total stats; running grand-total mirrored via a SCALAR pointer
// (%p_running points to %running, NOT into the nested struct — v0.2.0
// only supports addr of scalar locals / top-level scalar fields, see
// SPEC §148 + rule 15). Block 3 casts:  i32 -> f32 -> f64 -> i64.
struct @Stats12 {
  sum: f64;
  max: f64;
}
struct @Combo12 {
  row: @Stats12;
  total: @Stats12;
}

fun @main() : f64 {
  let mut %m: [3] [4] i32 = {{1, 2, 3, 4}, {-1, 5, -3, 7}, {2, -2, 4, 1}};
  let mut %v: [4] f32 = {0.5, 1.0, -0.25, 2.0};
  let mut %st: @Combo12 = {{0.0, 0.0}, {0.0, 0.0}};
  let mut %running: f64 = 0.0;
  let mut %p_running: ptr f64 = undef;
  let mut %i: i32 = 0;
  let mut %j: i32 = 0;
  let mut %mij: i32 = 0;
  let mut %vj: f32 = 0.0;
  let mut %tmp_f32: f32 = 0.0;
  let mut %tmp_f64: f64 = 0.0;
  let mut %tmp_i64: i64 = 0;
  let mut %two: i32 = 2;
  let mut %parity: i32 = 0;
^entry:
  %st.row.sum = 0.0;
  %st.row.max = 0.0;
  %st.total.sum = 0.0;
  %running = 0.0;
  %p_running = addr %running;
  %i = 0;
  br ^pre1;
^pre1:
  %two = 2;
  %tmp_f32 = 0.0;
  %tmp_f64 = 0.0;
  %parity = 0;
  store %p_running, %running;
  %tmp_i64 = 0;
  br ^pre2;
^pre2:
  %mij = 7;
  %tmp_f32 = %mij as f32;
  %tmp_f64 = %tmp_f32 as f64;
  %tmp_i64 = %tmp_f64 as i64;
  %st.row.max = %tmp_f64 + 0.0;
  %st.total.max = 0.0;
  br ^head;
^head:
  %st.row.sum = 0.0;
  %j = 0;
  %tmp_f64 = 0.0;
  %parity = %i % %two;
  %tmp_i64 = %i as i64;
  %tmp_f32 = %st.row.sum as f32;
  br %i < 3, ^body_a, ^post;
^body_a:
  %j = 0;
  %tmp_f64 = 0.0;
  %tmp_f32 = 0.0;
  %parity = %i + 0;
  %tmp_i64 = %i as i64;
  %st.row.sum = 0.0;
  br ^body_b;
^body_b:
  %mij = %m[%i][%j];
  %vj = %v[%j];
  %tmp_f32 = %mij as f32;
  %tmp_f32 = %tmp_f32 * %vj;
  %tmp_f64 = %tmp_f32 as f64;
  %st.row.sum = %st.row.sum + %tmp_f64;
  %j = %j + 1;
  br %j < 4, ^body_b, ^body_c;
^body_c:
  %st.total.sum = %st.total.sum + %st.row.sum;
  %running = %st.total.sum + 0.0;
  store %p_running, %running;
  %tmp_f64 = %st.row.sum + 0.0;
  %parity = %i + 0;
  %tmp_i64 = %i as i64;
  br ^body_d;
^body_d:
  %i = %i + 1;
  %tmp_f64 = load %p_running;
  %running = %tmp_f64 + 0.0;
  %tmp_i64 = %i as i64;
  %tmp_f32 = %running as f32;
  %parity = 0;
  br ^head;
^post:
  %tmp_f64 = load %p_running;
  %running = %tmp_f64 + 0.0;
  %tmp_f32 = %running as f32;
  %tmp_i64 = %tmp_f32 as i64;
  %tmp_f64 = %running + 0.0;
  %parity = 0;
  br ^exit;
^exit:
  %tmp_f64 = %st.total.sum + 0.0;
  %tmp_i64 = %tmp_f64 as i64;
  %tmp_f32 = %tmp_f64 as f32;
  %mij = %m[0][0] + 0;
  %parity = 0;
  %tmp_f64 = %tmp_f64 + 0.0;
  ret %tmp_f64;
}
