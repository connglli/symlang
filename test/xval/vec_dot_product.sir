// EXPECT: PASS
// EXPECT_RC: 70
// Vector dot product `<4> i32`: lane-wise multiply then sum lanes.
// Result must agree bit-exactly between symiri and symirc-emitted C.
fun @main() : i32 {
  let %a: <4> i32 = {1, 2, 3, 4};
  let %b: <4> i32 = {5, 6, 7, 8};
  let mut %p: <4> i32 = 0;
^entry:
  %p = %a * %b;            // {5, 12, 21, 32}
  ret %p[0] + %p[1] + %p[2] + %p[3];   // 70
}
