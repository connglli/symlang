// EXPECT: PASS
// EXPECT_RC: 100
// Several vectors with different widths (<2>, <3>, <4>, <8>). Tests
// that the implementation correctly handles non-power-of-2 widths in
// both backends.
fun @main() : i32 {
  let %v2: <2> i32 = {1, 2};
  let %v3: <3> i32 = {10, 20, 30};
  let %v8: <8> i32 = {1, 2, 3, 4, 5, 6, 7, 8};
  let mut %s2: i32 = 0;
  let mut %s3: i32 = 0;
  let mut %s8: i32 = 0;
^entry:
  %s2 = %v2[0] + %v2[1];                                                   // 3
  %s3 = %v3[0] + %v3[1] + %v3[2];                                          // 60
  %s8 = %v8[0] + %v8[1] + %v8[2] + %v8[3] + %v8[4] + %v8[5] + %v8[6] + %v8[7];   // 36
  ret %s2 + %s3 + %s8 + 1;   // 3 + 60 + 36 + 1 = 100
}
