// EXPECT: PASS
// EXPECT_RC: 100
// Several vectors with power-of-2 widths (<2>, <4>, <8>) plus an
// extra <4> to keep four shapes in the test. v0.2.1's spec permits
// non-power-of-2 widths (e.g., <3>), but the default `vecext`
// lowering relies on GCC's __attribute__((vector_size)) which
// rejects non-power-of-2 element counts. The `struct` / `array`
// lowerings (Phase 2) will not have this limitation and a
// <3>-version of this test will go in then.
fun @main() : i32 {
  let %v2: <2> i32 = {1, 2};
  let %v4: <4> i32 = {10, 20, 5, 25};
  let %v8: <8> i32 = {1, 2, 3, 4, 5, 6, 7, 8};
  let mut %s2: i32 = 0;
  let mut %s4: i32 = 0;
  let mut %s8: i32 = 0;
^entry:
  %s2 = %v2[0] + %v2[1];                                                   // 3
  %s4 = %v4[0] + %v4[1] + %v4[2] + %v4[3];                                 // 60
  %s8 = %v8[0] + %v8[1] + %v8[2] + %v8[3] + %v8[4] + %v8[5] + %v8[6] + %v8[7];   // 36
  ret %s2 + %s4 + %s8 + 1;   // 3 + 60 + 36 + 1 = 100
}
