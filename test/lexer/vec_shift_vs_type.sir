// EXPECT: PASS

// The lexer must distinguish `<<` (left-shift op) from two consecutive `<`
// tokens that the parser uses for nested vector contexts. Maximal-munch
// lexing should produce `<<` as a single token; `< 4 >` should produce
// three tokens. This test mixes both in one function to catch any greedy-
// match regressions.
fun @main() : i32 {
  let mut %sh: i32 = 1;
  let %vec_a: <4> i32 = {1, 2, 3, 4};
  let %vec_b: <4> i32 = {1, 1, 1, 1};
  let mut %vsum: <4> i32 = {0, 0, 0, 0};
^entry:
  %sh = %sh << 2;          // left-shift, single `<<` token
  %vsum = %vec_a + %vec_b; // vector add, type `<4> i32`
  ret 0;
}
